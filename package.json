{
	"name": "vscode-code-log-plus",
	"displayName": "CodeLog+ - Console Log & Debug for Any Language",
	"description": "CodeLog+ is a VS Code extension that turbocharges your debugging workflow by automating console log insertion, formatting, navigation, and cleanup across any programming language. Enjoy multi-language support, bulk log operations, tree-view explorer, accessibility-friendly modes, and performance optimizations—all in one developer-friendly tool.",
	"version": "1.12.1",
	"icon": "icon.png",
	"license": "MIT",
	"publisher": "imgildev",
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"sponsor": {
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"vscode": "^1.102.0",
		"node": ">=22"
	},
	"categories": [
		"Debuggers",
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"accessibility",
		"automation",
		"bulk log removal",
		"code debugging",
		"code",
		"comment log",
		"console log",
		"console.info",
		"console.log",
		"console.warn",
		"console",
		"cpp",
		"csharp",
		"custom log",
		"customizable logging",
		"dart",
		"debug console",
		"debug helper",
		"debug insertion",
		"debug log",
		"debug output",
		"debug print",
		"debug template",
		"debug",
		"debugging",
		"developer tools",
		"development",
		"elixir",
		"extension",
		"go",
		"haskell",
		"highlight log",
		"insert log",
		"java",
		"javascript",
		"kotlin",
		"log automation",
		"log formatting",
		"log generator",
		"log helper",
		"log insertion",
		"log level",
		"log management",
		"log manager",
		"log navigator",
		"log panel",
		"log shortcuts",
		"log snippet",
		"log statement",
		"log statements",
		"log template",
		"log",
		"logging",
		"logs",
		"lua",
		"multi-language",
		"perl",
		"php",
		"polyglot",
		"print statement",
		"print",
		"println",
		"productivity",
		"python",
		"remove log",
		"ruby",
		"runtime log",
		"scala",
		"swift",
		"tool",
		"turbo console log",
		"typescript",
		"uncomment log",
		"vscode",
		"wrap"
	],
	"homepage": "https://github.com/ManuelGil/vscode-code-log-plus",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/vscode-code-log-plus.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/vscode-code-log-plus/issues"
	},
	"activationEvents": [],
	"main": "./out/extension.js",
	"l10n": "./l10n",
	"files": [
		"out",
		"package*.json",
		"README.md",
		"LICENSE",
		"icon.png",
		"schemas",
		"l10n"
	],
	"contributes": {
		"configuration": {
			"type": "object",
			"title": "CodeLog+ Configuration",
			"properties": {
				"codeLogPlus.enable": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%codeLogPlus.enable.description%"
				},
				"codeLogPlus.defaultLanguage": {
					"type": "string",
					"default": "javascript",
					"enum": [
						"javascript",
						"typescript",
						"java",
						"csharp",
						"php",
						"dart",
						"python",
						"cpp",
						"ruby",
						"go",
						"kotlin",
						"swift",
						"scala",
						"lua",
						"perl",
						"elixir",
						"haskell"
					],
					"enumDescriptions": [
						"JavaScript",
						"TypeScript",
						"Java",
						"C#",
						"PHP",
						"Dart",
						"Python",
						"C++",
						"Ruby",
						"Go",
						"Kotlin",
						"Swift",
						"Scala",
						"Lua",
						"Perl",
						"Elixir",
						"Haskell"
					],
					"scope": "resource",
					"description": "%codeLogPlus.defaultLanguage.description%"
				},
				"codeLogPlus.logCommand": {
					"type": "string",
					"default": "",
					"scope": "resource",
					"description": "%codeLogPlus.logCommand.description%"
				},
				"codeLogPlus.isLogMessageWrapped": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%codeLogPlus.isLogMessageWrapped.description%"
				},
				"codeLogPlus.borderWrapCharacter": {
					"type": "string",
					"default": "-",
					"scope": "resource",
					"description": "%codeLogPlus.borderWrapCharacter.description%"
				},
				"codeLogPlus.borderWrapLength": {
					"type": "number",
					"default": 20,
					"minimum": 1,
					"scope": "resource",
					"description": "%codeLogPlus.borderWrapLength.description%"
				},
				"codeLogPlus.logMessagePrefix": {
					"type": "string",
					"default": "🔍",
					"scope": "resource",
					"description": "%codeLogPlus.logMessagePrefix.description%"
				},
				"codeLogPlus.useAccessibleLogs": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%codeLogPlus.useAccessibleLogs.description%"
				},
				"codeLogPlus.messageLogDelimiter": {
					"type": "string",
					"default": "~",
					"scope": "resource",
					"description": "%codeLogPlus.messageLogDelimiter.description%"
				},
				"codeLogPlus.messageLogSuffix": {
					"type": "string",
					"default": ":",
					"scope": "resource",
					"description": "%codeLogPlus.messageLogSuffix.description%"
				},
				"codeLogPlus.isSemicolonRequired": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%codeLogPlus.isSemicolonRequired.description%"
				},
				"codeLogPlus.addEmptyLineBeforeLogMessage": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%codeLogPlus.addEmptyLineBeforeLogMessage.description%"
				},
				"codeLogPlus.addEmptyLineAfterLog": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%codeLogPlus.addEmptyLineAfterLog.description%"
				},
				"codeLogPlus.useSingleQuotes": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%codeLogPlus.useSingleQuotes.description%"
				},
				"codeLogPlus.literalOpen": {
					"type": "string",
					"default": "{",
					"scope": "resource",
					"description": "%codeLogPlus.literalOpen.description%"
				},
				"codeLogPlus.literalClose": {
					"type": "string",
					"default": "}",
					"scope": "resource",
					"description": "%codeLogPlus.literalClose.description%"
				},
				"codeLogPlus.highlightColor": {
					"type": "string",
					"default": "#FFD700",
					"scope": "resource",
					"description": "%codeLogPlus.highlightColor.description%"
				},
				"codeLogPlus.highlightStyle": {
					"type": "string",
					"default": "wavy",
					"enum": [
						"solid",
						"double",
						"dotted",
						"dashed",
						"wavy"
					],
					"enumDescriptions": [
						"Solid Line",
						"Double Line",
						"Dotted Line",
						"Dashed Line",
						"Wavy Line"
					],
					"scope": "resource",
					"description": "%codeLogPlus.highlightStyle.description%"
				},
				"codeLogPlus.customLogTemplates": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"language": {
								"type": "string",
								"enum": [
									"javascript",
									"typescript",
									"java",
									"csharp",
									"php",
									"dart",
									"python",
									"cpp",
									"ruby",
									"go",
									"kotlin",
									"swift",
									"scala",
									"lua",
									"perl",
									"elixir",
									"haskell"
								],
								"enumDescriptions": [
									"JavaScript",
									"TypeScript",
									"Java",
									"C#",
									"PHP",
									"Dart",
									"Python",
									"C++",
									"Ruby",
									"Go",
									"Kotlin",
									"Swift",
									"Scala",
									"Lua",
									"Perl",
									"Elixir",
									"Haskell"
								],
								"description": "%codeLogPlus.customLogTemplates.language.description%"
							},
							"template": {
								"type": "string",
								"description": "%codeLogPlus.customLogTemplates.template.description%"
							}
						},
						"required": [
							"language",
							"template"
						]
					},
					"default": [],
					"scope": "resource",
					"description": "%codeLogPlus.customLogTemplates.description%"
				},
				"codeLogPlus.files.includedFilePatterns": {
					"type": "array",
					"default": [
						"**/*.{js,jsx,ts,tsx}"
					],
					"scope": "resource",
					"description": "%codeLogPlus.files.includedFilePatterns.description%"
				},
				"codeLogPlus.files.excludedFilePatterns": {
					"type": "array",
					"default": [
						"**/node_modules/**",
						"**/dist/**",
						"**/out/**",
						"**/build/**",
						"**/vendor/**"
					],
					"scope": "resource",
					"description": "%codeLogPlus.files.excludedFilePatterns.description%"
				},
				"codeLogPlus.files.maxSearchRecursionDepth": {
					"type": "number",
					"default": 0,
					"scope": "resource",
					"description": "%codeLogPlus.files.maxSearchRecursionDepth.description%"
				},
				"codeLogPlus.files.supportsHiddenFiles": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%codeLogPlus.files.supportsHiddenFiles.description%"
				},
				"codeLogPlus.files.preserveGitignoreSettings": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%codeLogPlus.files.preserveGitignoreSettings.description%"
				},
				"codeLogPlus.files.includeFilePath": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%codeLogPlus.files.includeFilePath.description%"
				}
			}
		},
		"commands": [
			{
				"command": "codeLogPlus.insertLog",
				"title": "%codeLogPlus.insertLog.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.editLogs",
				"title": "%codeLogPlus.editLogs.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.removeLogs",
				"title": "%codeLogPlus.removeLogs.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.highlightLogs",
				"title": "%codeLogPlus.highlightLogs.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.clearHighlights",
				"title": "%codeLogPlus.clearHighlights.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.commentLogs",
				"title": "%codeLogPlus.commentLogs.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.uncommentLogs",
				"title": "%codeLogPlus.uncommentLogs.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.listLogView.openContainingFolder",
				"title": "%codeLogPlus.listLogView.openContainingFolder.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.listLogView.revealFile",
				"title": "%codeLogPlus.listLogView.revealFile.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.listLogView.copyPath",
				"title": "%codeLogPlus.listLogView.copyPath.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.listLogView.gotoLineFromNode",
				"title": "%codeLogPlus.listLogView.gotoLineFromNode.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.listLogView.copyLogText",
				"title": "%codeLogPlus.listLogView.copyLogText.title%",
				"category": "CodeLog+"
			},
			{
				"command": "codeLogPlus.listLogView.refreshList",
				"title": "%codeLogPlus.listLogView.refreshList.title%",
				"category": "CodeLog+",
				"icon": "$(refresh)"
			}
		],
		"keybindings": [
			{
				"key": "ctrl+alt+l",
				"command": "codeLogPlus.insertLog",
				"when": "editorTextFocus",
				"description": "Insert log statement for selected variable (Windows & Linux)"
			},
			{
				"key": "cmd+alt+l",
				"command": "codeLogPlus.insertLog",
				"when": "editorTextFocus",
				"description": "Insert log statement for selected variable (macOS)"
			},
			{
				"key": "ctrl+alt+shift+l",
				"command": "codeLogPlus.removeLogs",
				"when": "editorTextFocus",
				"description": "Remove all inserted log statements (Windows & Linux)"
			},
			{
				"key": "cmd+alt+shift+l",
				"command": "codeLogPlus.removeLogs",
				"when": "editorTextFocus",
				"description": "Remove all inserted log statements (macOS)"
			},
			{
				"key": "ctrl+alt+a",
				"command": "codeLogPlus.editLogs",
				"when": "editorTextFocus",
				"description": "Edit selected log statement(s) (Windows & Linux)"
			},
			{
				"key": "cmd+alt+a",
				"command": "codeLogPlus.editLogs",
				"when": "editorTextFocus",
				"description": "Edit selected log statement(s) (macOS)"
			},
			{
				"key": "ctrl+alt+k",
				"command": "codeLogPlus.highlightLogs",
				"when": "editorTextFocus",
				"description": "Highlight all inserted log statements (Windows & Linux)"
			},
			{
				"key": "cmd+alt+k",
				"command": "codeLogPlus.highlightLogs",
				"when": "editorTextFocus",
				"description": "Highlight all inserted log statements (macOS)"
			},
			{
				"key": "ctrl+alt+shift+k",
				"command": "codeLogPlus.clearHighlights",
				"when": "editorTextFocus",
				"description": "Unhighlight all previously highlighted log statements (Windows & Linux)"
			},
			{
				"key": "cmd+alt+shift+k",
				"command": "codeLogPlus.clearHighlights",
				"when": "editorTextFocus",
				"description": "Unhighlight all previously highlighted log statements (macOS)"
			},
			{
				"key": "ctrl+alt+,",
				"command": "codeLogPlus.commentLogs",
				"when": "editorTextFocus",
				"description": "Comment out all inserted log statements (Windows & Linux)"
			},
			{
				"key": "cmd+alt+,",
				"command": "codeLogPlus.commentLogs",
				"when": "editorTextFocus",
				"description": "Comment out all inserted log statements (macOS)"
			},
			{
				"key": "ctrl+alt+shift+,",
				"command": "codeLogPlus.uncommentLogs",
				"when": "editorTextFocus",
				"description": "Uncomment all previously commented log statements (Windows & Linux)"
			},
			{
				"key": "cmd+alt+shift+,",
				"command": "codeLogPlus.uncommentLogs",
				"when": "editorTextFocus",
				"description": "Uncomment all previously commented log statements (macOS)"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "codeLogPlus.insertLog",
					"group": "1_modification",
					"when": "editorTextFocus"
				}
			],
			"view/title": [
				{
					"command": "codeLogPlus.listLogView.refreshList",
					"when": "view == codeLogPlus.listLogView",
					"group": "navigation@1"
				}
			],
			"view/item/context": [
				{
					"command": "codeLogPlus.listLogView.revealFile",
					"when": "view == codeLogPlus.listLogView && viewItem == file",
					"group": "navigation@1"
				},
				{
					"command": "codeLogPlus.listLogView.openContainingFolder",
					"when": "view == codeLogPlus.listLogView && viewItem == file",
					"group": "navigation@2"
				},
				{
					"command": "codeLogPlus.listLogView.copyPath",
					"when": "view == codeLogPlus.listLogView && viewItem == file",
					"group": "2_workspace@1"
				},
				{
					"command": "codeLogPlus.listLogView.gotoLineFromNode",
					"when": "view == codeLogPlus.listLogView && viewItem == log",
					"group": "navigation@1"
				},
				{
					"command": "codeLogPlus.listLogView.copyLogText",
					"when": "view == codeLogPlus.listLogView && viewItem == log",
					"group": "2_workspace@1"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "codeLogPlus.listLogView",
				"contents": "%codeLogPlus.listLogView.welcomeMessage%"
			}
		],
		"views": {
			"explorer": [
				{
					"id": "codeLogPlus.listLogView",
					"name": "%codeLogPlus.listLogView.title%",
					"visibility": "visible",
					"icon": "$(list-tree)"
				}
			]
		},
		"jsonValidation": [
			{
				"fileMatch": ".vscode/settings.json",
				"url": "./schemas/config.schema.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm compile",
		"typecheck": "tsc --noEmit -p ./",
		"compile": "pnpm typecheck && rimraf out && esbuild src/extension.ts --bundle --platform=node --target=node22 --format=cjs --external:vscode --outfile=out/extension.js --minify",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm compile && tsc -p ./ && pnpm lint",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write --unsafe .",
		"test": "vscode-test",
		"test:unit": "mocha -r ts-node/register src/**/*.test.ts",
		"l10n:check": "node scripts/check-l10n.js",
		"nls:check": "node scripts/check-nls.js",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@types/mocha": "^10.0.10",
		"@types/mustache": "^4.2.6",
		"@types/node": "^22.20.1",
		"@types/vscode": "^1.102.0",
		"@vscode/l10n-dev": "^0.0.35",
		"@vscode/test-cli": "^0.0.15",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.28.1",
		"glob": "^13.0.6",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"minimatch": "^10.2.5",
		"mocha": "^11.7.6",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"fast-glob": "^3.3.3",
		"ignore": "^7.0.6",
		"mustache": "^4.2.0",
		"p-limit": "^7.3.0",
		"vscode-marketplace-client": "^1.2.4"
	},
	"pnpm": {
		"overrides": {
			"@conventional-changelog/git-client@<2.0.0": ">=2.0.0",
			"diff@>=6.0.0 <8.0.3": ">=8.0.3",
			"serialize-javascript@>=5.0.0 <7.0.5": ">=7.0.5",
			"markdown-it@<=14.1.1": ">=14.2.0"
		},
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
